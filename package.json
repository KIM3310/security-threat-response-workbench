{
  "name": "security-threat-response-workbench",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare:sample": "python3 scripts/build_security_snapshot.py",
    "verify:security": "bash scripts/verify_snapshot.sh",
    "lint": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run prepare:sample && npm run typecheck && npm test && npm run build && npm run verify:security",
    "cf:deploy": "npm run prepare:sample && npm run build && wrangler deploy",
    "cf:deploy:dry": "npm run prepare:sample && npm run build && wrangler deploy --dry-run"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "ws": "^8.20.1"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
